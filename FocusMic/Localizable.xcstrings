    "守护" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Guard" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ガード" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "보호" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "守護" } }
      }
    },
    "守护输入设备" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Guard Input Device" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "入力デバイスを保護" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "입력 장치 보호" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "守護輸入裝置" } }
      }
    },
    "只要锁定设备在线，系统输入会自动保持为该设备；被切走后自动切回。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "As long as the locked device is online, the system input stays on it and switches back automatically if changed." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ロックしたデバイスがオンラインの間、システム入力を自動的に維持し、切り替えられた場合は自動で戻します。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "잠근 장치가 온라인이면 시스템 입력을 해당 장치로 유지하고, 변경되면 자동으로 되돌립니다." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "只要鎖定裝置在線，系統輸入會自動保持為該裝置；被切走後自動切回。" } }
      }
    },
    "锁定输入音量" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Lock Input Volume" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "入力音量をロック" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "입력 음량 잠금" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "鎖定輸入音量" } }
      }
    },
    "有些应用会偷偷改麦克风增益；开启后音量被改动时自动恢复。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Some apps silently change the microphone gain; when enabled, the volume is restored automatically if changed." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "一部のアプリはマイクゲインを勝手に変更します。オンにすると、音量が変更された場合に自動で復元します。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "일부 앱은 마이크 게인을 몰래 변경합니다. 켜면 음량이 변경될 때 자동으로 복원합니다." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "有些應用會偷偷改麥克風增益；開啟後音量被改動時自動恢復。" } }
      }
    },
    "输入电平" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Input Level" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "入力レベル" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "입력 레벨" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "輸入電平" } }
      }
    },
    "显示实时输入电平" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Show Live Input Level" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "リアルタイム入力レベルを表示" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "실시간 입력 레벨 표시" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "顯示即時輸入電平" } }
      }
    },
    "本地实时采样计算响度，不录制、不保存任何音频；首次开启需要麦克风权限。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Loudness is computed from local real-time sampling; no audio is recorded or saved. Microphone permission is required on first use." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ローカルでリアルタイムにサンプリングして音量を計算します。録音や保存は行いません。初回はマイクの許可が必要です。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "로컬에서 실시간 샘플링으로 음량을 계산하며, 오디오를 녹음하거나 저장하지 않습니다. 처음 켤 때 마이크 권한이 필요합니다." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "本地即時取樣計算響度，不錄製、不儲存任何音訊；首次開啟需要麥克風權限。" } }
      }
    },
